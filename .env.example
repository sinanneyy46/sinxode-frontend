# Development (recommended): leave VITE_API_URL unset to use Vite /api proxy.
# VITE_API_URL=

# Development (optional direct backend):
# VITE_API_URL=http://localhost:8000
# VITE_API_URL_DEV=http://localhost:8000

# Development safety:
# If VITE_API_URL points to production, local runtime will ignore it unless you force it.
# VITE_USE_PROD_API_IN_DEV=false

# Production (set in Vercel environment variables):
# VITE_API_URL=https://sinxode-backend.onrender.com
